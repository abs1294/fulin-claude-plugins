        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/qa-landing-gate.js\"",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
